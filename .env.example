# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (software fee only - never the entry pot)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Football data API
FOOTBALL_DATA_API_KEY=your-football-data-org-api-key

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=Sweep or Weep <notifications@sweeporweep.com>
# Set to "log" in development to print emails to console instead of sending
MAIL_TRANSPORT=log

# Cron secret (for scheduled jobs)
CRON_SECRET=your-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
